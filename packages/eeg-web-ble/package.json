{
	"name": "@elata-biosciences/eeg-web-ble",
	"version": "0.2.1",
	"description": "Web Bluetooth headband transport that emits normalized headband frames",
	"license": "MIT",
	"author": "Elata",
	"repository": {
		"type": "git",
		"url": "https://github.com/Elata-Biosciences/elata-bio-sdk.git",
		"directory": "packages/eeg-web-ble"
	},
	"homepage": "https://github.com/Elata-Biosciences/elata-bio-sdk#readme",
	"bugs": "https://github.com/Elata-Biosciences/elata-bio-sdk/issues",
	"keywords": [
		"eeg",
		"bci",
		"neuroscience",
		"brain-computer-interface",
		"headband",
		"elata",
		"web-bluetooth",
		"ble"
	],
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"llms.txt"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"lint": "pnpm exec biome lint src jest.config.cjs",
		"test": "jest --config ./jest.config.cjs --passWithNoTests",
		"clean": "node ./scripts/clean.mjs",
		"build": "tsc -p tsconfig.json",
		"verify:build": "node ../../scripts/verify-package-build.mjs dist/index.js dist/index.d.ts",
		"verify:publish": "pnpm run verify:build",
		"prepare:publish": "pnpm run build",
		"prepack": "pnpm run prepare:publish && pnpm run verify:publish",
		"pack:check": "pnpm pack --dry-run --json"
	},
	"peerDependencies": {
		"@elata-biosciences/eeg-web": "^0.2.1"
	},
	"devDependencies": {
		"@elata-biosciences/eeg-web": "workspace:*",
		"@types/jest": "29.5.14",
		"jest": "29.7.0",
		"jest-environment-jsdom": "29.7.0",
		"ts-jest": "29.4.4",
		"typescript": "5.9.3"
	}
}
