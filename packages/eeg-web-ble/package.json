{
  "name": "@elata-biosciences/eeg-web-ble",
  "version": "0.1.0",
  "description": "Web Bluetooth headband transport that emits normalized headband frames",
  "license": "MIT",
  "author": "Elata",
  "repository": {
    "type": "git",
    "url": "https://github.com/elata-bio/elata-sdk.git",
    "directory": "packages/eeg-web-ble"
  },
  "homepage": "https://github.com/elata-bio/elata-sdk#readme",
  "bugs": "https://github.com/elata-bio/elata-sdk/issues",
  "keywords": [
    "eeg",
    "bci",
    "neuroscience",
    "brain-computer-interface",
    "headband",
    "elata",
    "web-bluetooth",
    "ble"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest --config ./jest.config.cjs --passWithNoTests",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "build": "tsc -p tsconfig.json",
    "verify:build": "node ../../scripts/verify-package-build.mjs dist/index.js dist/index.d.ts",
    "prepack": "pnpm --filter @elata-biosciences/eeg-web run prepack && pnpm clean && pnpm build && pnpm verify:build",
    "pack:check": "npm_config_cache=${NPM_CONFIG_CACHE:-/tmp/npm-cache} npm pack --dry-run"
  },
  "dependencies": {
    "@elata-biosciences/eeg-web": "workspace:^0.1.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.3",
    "jest": "29.6.1",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "29.1.0",
    "typescript": "^5.3.3"
  }
}
