{
  "name": "@elata-biosciences/create-elata-demo",
  "version": "0.1.24",
  "description": "Scaffold Elata starter apps from multiple templates",
  "license": "MIT",
  "author": "Elata",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elata-Biosciences/elata-bio-sdk.git",
    "directory": "packages/create-elata-demo"
  },
  "homepage": "https://github.com/Elata-Biosciences/elata-bio-sdk#readme",
  "bugs": "https://github.com/Elata-Biosciences/elata-bio-sdk/issues",
  "keywords": [
    "elata",
    "create",
    "scaffold",
    "demo",
    "eeg",
    "rppg",
    "ppg"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "elataSdkVersions": {
    "eegWeb": "0.1.23",
    "eegWebBle": "0.1.23",
    "rppgWeb": "0.1.23",
    "ppgWeb": "0.1.3"
  },
  "bin": {
    "create-elata-demo": "index.mjs"
  },
  "scripts": {
    "test": "node --test index.test.mjs",
    "verify:publish": "node ../../scripts/verify-package-build.mjs index.mjs templates/rppg-demo/package.json templates/ppg-demo/package.json templates/eeg-demo/package.json",
    "prepare:publish": "pnpm run verify:publish",
    "prepack": "pnpm run prepare:publish && pnpm run verify:publish"
  },
  "files": [
    "index.mjs",
    "templates",
    "README.md",
    "llms.txt"
  ],
  "publishConfig": {
    "access": "public"
  }
}
