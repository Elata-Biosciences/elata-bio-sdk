{
  "name": "@elata-biosciences/eeg-web",
  "version": "0.1.4",
  "description": "Web wrapper for the Elata EEG WASM bindings",
  "license": "MIT",
  "author": "Elata",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elata-Biosciences/elata-bio-sdk.git",
    "directory": "packages/eeg-web"
  },
  "homepage": "https://github.com/Elata-Biosciences/elata-bio-sdk#readme",
  "bugs": "https://github.com/Elata-Biosciences/elata-bio-sdk/issues",
  "keywords": [
    "eeg",
    "bci",
    "neuroscience",
    "brain-computer-interface",
    "muse",
    "elata",
    "wasm"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wasm/*": "./wasm/*"
  },
  "files": [
    "dist",
    "wasm/*.js",
    "wasm/*.ts",
    "wasm/*.wasm",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "pnpm exec biome lint src scripts/verify-wasm.js jest.config.cjs",
    "test": "jest --config jest.config.cjs --passWithNoTests",
    "test:coverage": "jest --config jest.config.cjs --coverage --passWithNoTests",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "build": "tsc -p tsconfig.json",
    "sync-wasm": "bash ./scripts/sync-wasm.sh",
    "verify:build": "node ../../scripts/verify-package-build.mjs dist/index.js dist/index.d.ts",
    "verify:wasm": "node ./scripts/verify-wasm.js",
    "prepack": "node ../../scripts/verify-package-build.mjs dist/index.js dist/index.d.ts"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "ts-jest": "29.4.4",
    "typescript": "5.9.3"
  }
}
