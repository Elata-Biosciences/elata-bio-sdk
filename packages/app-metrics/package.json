{
	"name": "@elata-biosciences/app-metrics",
	"version": "0.1.0",
	"description": "Per-user, per-app metrics storage for sandboxed apps in the Elata App Store. Apps record events through a MessageChannel; the host owns storage and namespacing.",
	"license": "MIT",
	"author": "Elata",
	"repository": {
		"type": "git",
		"url": "https://github.com/Elata-Biosciences/elata-bio-sdk.git",
		"directory": "packages/app-metrics"
	},
	"homepage": "https://github.com/Elata-Biosciences/elata-bio-sdk#readme",
	"bugs": "https://github.com/Elata-Biosciences/elata-bio-sdk/issues",
	"keywords": ["elata", "appstore", "sandbox", "metrics", "storage", "postmessage"],
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./host": {
			"types": "./dist/host.d.ts",
			"import": "./dist/host.js"
		}
	},
	"files": ["dist", "README.md", "llms.txt"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"lint": "pnpm exec biome lint src jest.config.cjs",
		"test": "jest --config jest.config.cjs --passWithNoTests",
		"test:coverage": "jest --config jest.config.cjs --coverage --passWithNoTests",
		"clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
		"build": "tsc -p tsconfig.json"
	},
	"devDependencies": {
		"@types/jest": "29.5.14",
		"fake-indexeddb": "6.0.0",
		"jest": "29.7.0",
		"jest-environment-jsdom": "29.7.0",
		"ts-jest": "29.4.4",
		"typescript": "5.9.3"
	}
}
