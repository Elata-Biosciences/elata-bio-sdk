{
  "private": true,
  "name": "elata-sdk",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "workspaces": [
    "packages/*",
    "eeg-demo"
  ],
  "scripts": {
    "audit:repo": "node scripts/audit-repo.mjs",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "clean": "pnpm -r --if-present clean",
    "lint:web": "pnpm -r --if-present lint",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "lint": "pnpm run audit:repo && pnpm run lint:web && pnpm run lint:rust",
    "verify:build": "pnpm -r --if-present verify:build",
    "verify:all": "pnpm run audit:repo && pnpm run lint:web && pnpm run verify:build && pnpm --filter @elata-biosciences/eeg-web --if-present verify:wasm",
    "validate:tarballs": "node scripts/validate-tarballs.mjs",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.27.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
