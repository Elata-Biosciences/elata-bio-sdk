{
	"private": true,
	"name": "elata-sdk",
	"packageManager": "pnpm@10.31.0",
	"engines": {
		"node": ">=20",
		"pnpm": ">=10"
	},
	"scripts": {
		"audit:repo": "node scripts/audit-repo.mjs",
		"build": "pnpm -r --if-present build",
		"cross-modal:toy:subset": "python scripts/cross_modal/make_toy_subset.py --config configs/cross_modal/proto_cpu.toml",
		"cross-modal:toy:smoke": "python scripts/cross_modal/train_proto.py --config configs/cross_modal/proto_cpu.toml",
		"cross-modal:toy:validate": "python scripts/cross_modal/validate_toy_run.py --config configs/cross_modal/proto_cpu.toml",
		"cross-modal:toy:all": "python scripts/cross_modal/make_toy_subset.py --config configs/cross_modal/proto_cpu.toml && python scripts/cross_modal/train_proto.py --config configs/cross_modal/proto_cpu.toml && python scripts/cross_modal/validate_toy_run.py --config configs/cross_modal/proto_cpu.toml",
		"cross-modal:manifest:validate": "python scripts/cross_modal/validate_manifest_file.py manifests/cross_modal/public_ds004514.json",
		"test": "pnpm -r --if-present test",
		"clean": "pnpm -r --if-present clean",
		"lint:web": "pnpm -r --if-present lint",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
		"lint": "pnpm run audit:repo && pnpm run format:check && pnpm run lint:web && pnpm run lint:rust",
		"verify:build": "pnpm -r --if-present verify:build",
		"verify:all": "pnpm run audit:repo && pnpm run lint:web && pnpm run verify:build && pnpm --filter @elata-biosciences/eeg-web --if-present verify:wasm",
		"validate:tarballs": "node scripts/validate-tarballs.mjs",
		"changeset": "changeset",
		"version": "changeset version"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@changesets/cli": "^2.27.10"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
	}
}
