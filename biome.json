{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      "**/__tests__/**",
      "packages/eeg-web/wasm/**",
      "packages/rppg-web/demo/**",
      "packages/rppg-web/e2e/**"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off",
        "useOptionalChain": "off"
      },
      "style": {
        "noInferrableTypes": "off",
        "noNonNullAssertion": "off",
        "useImportType": "off",
        "useNumberNamespace": "off",
        "useSingleVarDeclarator": "off"
      },
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  }
}
